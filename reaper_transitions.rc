// ---------------------------------------------------------------------------
// IDD_LIVE_OPTIMIZE  -  Live Optimizer window  (560 x 380 DU)
//
//  Top  (y 3..22)  : score bar (owner-draw) + score text label
//  Mid  (y 25..280): SysListView32 placeholder (replaced dynamically)
//  Lower(y 283..315): info / tooltip multi-line text
//  Bottom (y 320..337): Refresh button + status text
// ---------------------------------------------------------------------------

IDD_LIVE_OPTIMIZE DIALOGEX 0, 0, 560, 380
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Live Tools - Live Optimizer"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // ---- Score bar (owner-draw) ----------------------------------------
    CONTROL         "", IDC_LO_SCORE_BAR,  "Static",
                    SS_OWNERDRAW | WS_VISIBLE, 5, 3, 440, 18
    LTEXT           "Live Score: -- / 100", IDC_LO_SCORE_TEXT, 450, 6, 105, 12

    // ---- ListView placeholder – replaced dynamically in WM_INITDIALOG --
    LTEXT           "", IDC_LO_LIST, 5, 25, 550, 255

    // ---- Info / tooltip panel ------------------------------------------
    EDITTEXT        IDC_LO_INFO, 5, 285, 550, 46,
                    ES_MULTILINE | ES_READONLY | WS_VSCROLL | WS_BORDER | NOT WS_TABSTOP

    // ---- Bottom action row ---------------------------------------------
    PUSHBUTTON      "Refresh",   IDC_LO_REFRESH,   5,   337, 55, 14
    LTEXT           "",          IDC_LO_STATUS,    65,  340, 490, 10
END

// ---- Control Surface config dialog ----------------------------------------
IDD_CSURF_CONFIG DIALOGEX 0, 0, 310, 214
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    LTEXT           "Template:",        IDC_STATIC,          5,  6,  46, 8
    COMBOBOX        IDC_CSURF_TEMPLATE, 54, 4, 250, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "",                 IDC_CSURF_DESC,      5, 18, 300, 8

    GROUPBOX        "Protocol",         IDC_STATIC,          5, 30, 130, 20
    CONTROL         "MCU",              IDC_CSURF_PROTO_MCU, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 12, 40, 36, 10
    CONTROL         "HUI",              IDC_CSURF_PROTO_HUI, "Button", BS_AUTORADIOBUTTON,                          60, 40, 36, 10

    LTEXT           "MIDI Input:",      IDC_STATIC,          5, 56, 48, 8
    COMBOBOX        IDC_CSURF_MIDI_IN,  54, 54, 250, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "MIDI Output:",     IDC_STATIC,          5, 70, 48, 8
    COMBOBOX        IDC_CSURF_MIDI_OUT, 54, 68, 250, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Ext. Input:",      IDC_STATIC,          5, 84, 48, 8
    COMBOBOX        IDC_CSURF_MIDI_IN2, 54, 82, 250, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Ext. Output:",     IDC_STATIC,          5, 98, 48, 8
    COMBOBOX        IDC_CSURF_MIDI_OUT2,54, 96, 250, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    CONTROL         "Fader follows track selection",  IDC_CSURF_FOLLOW_SEL, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 5, 114, 160, 10
    CONTROL         "Show VU meters",                 IDC_CSURF_SHOW_VU,    "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 5, 128, 130, 10
    CONTROL         "Show track names on LCD",        IDC_CSURF_SHOW_NAMES, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 5, 142, 150, 10

    GROUPBOX        "Fader assigns",    IDC_STATIC,          5, 156, 180, 24
    CONTROL         "Volume",           IDC_CSURF_FADER_VOL, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,  12, 166, 46, 10
    CONTROL         "Pan",              IDC_CSURF_FADER_PAN, "Button", BS_AUTORADIOBUTTON,                           62, 166, 36, 10
    CONTROL         "Sends",            IDC_CSURF_FADER_SEND,"Button", BS_AUTORADIOBUTTON,                          102, 166, 46, 10

    CONTROL         "Send track colors to scribble strips", IDC_CSURF_SEND_COLORS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  5, 186, 200, 10
    CONTROL         "Follow MCP (mixer) track order",       IDC_CSURF_FOLLOW_MCP,  "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  5, 200, 200, 10
END

// Standalone version (same controls + OK/Cancel, opened from Extensions menu)
IDD_CSURF_STANDALONE DIALOGEX 0, 0, 310, 234
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Control Surface Settings"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    LTEXT           "Template:",        IDC_STATIC,          5,  6,  46, 8
    COMBOBOX        IDC_CSURF_TEMPLATE, 54, 4, 250, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "",                 IDC_CSURF_DESC,      5, 18, 300, 8

    GROUPBOX        "Protocol",         IDC_STATIC,          5, 30, 130, 20
    CONTROL         "MCU",              IDC_CSURF_PROTO_MCU, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 12, 40, 36, 10
    CONTROL         "HUI",              IDC_CSURF_PROTO_HUI, "Button", BS_AUTORADIOBUTTON,                          60, 40, 36, 10

    LTEXT           "MIDI Input:",      IDC_STATIC,          5, 56, 48, 8
    COMBOBOX        IDC_CSURF_MIDI_IN,  54, 54, 250, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "MIDI Output:",     IDC_STATIC,          5, 70, 48, 8
    COMBOBOX        IDC_CSURF_MIDI_OUT, 54, 68, 250, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Ext. Input:",      IDC_STATIC,          5, 84, 48, 8
    COMBOBOX        IDC_CSURF_MIDI_IN2, 54, 82, 250, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Ext. Output:",     IDC_STATIC,          5, 98, 48, 8
    COMBOBOX        IDC_CSURF_MIDI_OUT2,54, 96, 250, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    CONTROL         "Fader follows track selection",  IDC_CSURF_FOLLOW_SEL, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 5, 114, 160, 10
    CONTROL         "Show VU meters",                 IDC_CSURF_SHOW_VU,    "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 5, 128, 130, 10
    CONTROL         "Show track names on LCD",        IDC_CSURF_SHOW_NAMES, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 5, 142, 150, 10

    GROUPBOX        "Fader assigns",    IDC_STATIC,          5, 156, 180, 24
    CONTROL         "Volume",           IDC_CSURF_FADER_VOL, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,  12, 166, 46, 10
    CONTROL         "Pan",              IDC_CSURF_FADER_PAN, "Button", BS_AUTORADIOBUTTON,                           62, 166, 36, 10
    CONTROL         "Sends",            IDC_CSURF_FADER_SEND,"Button", BS_AUTORADIOBUTTON,                          102, 166, 46, 10

    CONTROL         "Send track colors to scribble strips", IDC_CSURF_SEND_COLORS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  5, 186, 200, 10
    CONTROL         "Follow MCP (mixer) track order",       IDC_CSURF_FOLLOW_MCP,  "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  5, 200, 200, 10

    DEFPUSHBUTTON   "OK",               IDOK,                200, 216, 50, 14
    PUSHBUTTON      "Cancel",           IDCANCEL,            256, 216, 50, 14
END

// ---------------------------------------------------------------------------
// Up-down (spin) control styles – not defined in winres.h
// ---------------------------------------------------------------------------
#ifndef UDS_SETBUDDYINT
#define UDS_SETBUDDYINT  0x0002
#define UDS_ALIGNRIGHT   0x0008
#define UDS_ARROWKEYS    0x0020
#endif

// ---------------------------------------------------------------------------
// IDD_LIVELOCK  -  Live Safe Locking bar  (300 x 22 DU)
// Entirely custom-painted; no child controls needed here.
// ---------------------------------------------------------------------------
IDD_LIVELOCK DIALOGEX 0, 0, 300, 22
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Live Lock"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
END

// ---------------------------------------------------------------------------
// IDD_LIVELOCK_SETTINGS  -  Live Lock settings  (250 x 215 DU)
// ---------------------------------------------------------------------------
IDD_LIVELOCK_SETTINGS DIALOGEX 0, 0, 250, 215
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Live Lock Settings"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    GROUPBOX "Protect", IDC_STATIC, 5, 4, 240, 98
    CONTROL "All routing (track sends)",            IDC_LL_CHK_ROUTING,    "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  12, 17, 200, 10
    CONTROL "Selected tracks only (at lock time)",  IDC_LL_CHK_SELONLY,    "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  22, 29, 210, 10
    CONTROL "Hardware outputs",                     IDC_LL_CHK_HWOUT,      "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  12, 41, 200, 10
    CONTROL "Master send enable/disable",           IDC_LL_CHK_MASTERSEND, "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  12, 53, 200, 10
    CONTROL "FX bypass states",                     IDC_LL_CHK_FXBYPASS,   "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  12, 65, 200, 10
    CONTROL "Record arm / input monitoring",        IDC_LL_CHK_RECARM,     "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  12, 77, 200, 10

    GROUPBOX "On violation", IDC_STATIC, 5, 106, 240, 24
    CONTROL "Require confirmation before reverting", IDC_LL_CHK_CONFIRM, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 12, 118, 225, 10

    LTEXT    "Check interval:", IDC_STATIC, 5, 136, 64, 10, SS_CENTERIMAGE
    EDITTEXT IDC_LL_INTERVAL_EDIT, 72, 134, 38, 14, ES_NUMBER | ES_AUTOHSCROLL
    CONTROL  "", IDC_LL_INTERVAL_SPIN, "msctls_updown32",
             UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_ARROWKEYS | WS_CHILD | WS_VISIBLE,
             110, 134, 12, 14
    LTEXT    "ms  (50 - 2000)", IDC_STATIC, 124, 136, 80, 10, SS_CENTERIMAGE
    LTEXT    "Lower values revert faster, higher CPU usage.", IDC_STATIC, 5, 152, 240, 10

    DEFPUSHBUTTON "OK",     IDOK,     140, 195, 50, 14
    PUSHBUTTON    "Cancel", IDCANCEL, 196, 195, 50, 14
END
