#include "winres.h"
#include "resource.h"

// CommCtrl list-view styles (not in winres.h)
#ifndef LVS_REPORT
#define LVS_REPORT        0x0001
#define LVS_SINGLESEL     0x0004
#define LVS_SHOWSELALWAYS 0x0008
#define LVS_EDITLABELS    0x0200
#endif
// CommCtrl progress-bar style
#ifndef PBS_SMOOTH
#define PBS_SMOOTH        0x01
#endif
// CommCtrl trackbar style
#ifndef TBS_NOTICKS
#define TBS_NOTICKS       0x0010
#endif

// ---------------------------------------------------------------------------
// IDD_TSNAPS  -  Scenes main window  (258 x 116 DU)
//   Left  (x 5-153)   : scene list (built dynamically)
//   Right (x 158-255) : controls (~97 DU wide)
// ---------------------------------------------------------------------------

IDD_TSNAPS DIALOGEX 0, 0, 258, 175
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Scenes"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // ---- Mode toggle buttons (Scenes / Cue List) -------------------------
    CONTROL         "Scenes",   IDC_MODE_SCENES, "Button", BS_AUTOCHECKBOX | BS_PUSHLIKE | WS_TABSTOP, 5, 3, 72, 13
    CONTROL         "Cue List", IDC_MODE_CUE,    "Button", BS_AUTOCHECKBOX | BS_PUSHLIKE | WS_TABSTOP, 79, 3, 74, 13

    // ---- List view placeholder – replaced dynamically in WM_INITDIALOG ----
    LTEXT           "", IDC_LIST, 5, 19, 148, 153

    // ---- Top action buttons -----------------------------------------------
    PUSHBUTTON      "&New",       IDC_SAVE,         158,  3, 46, 13
    PUSHBUTTON      "Recall",     IDC_RECALL,       207,  3, 48, 13

    // ---- Snapshot name editor --------------------------------------------
    LTEXT           "Name:",  IDC_STATIC,     158, 22, 22,  8
    EDITTEXT        IDC_SNAPNAME,             182, 20, 73, 12, ES_AUTOHSCROLL

    // ---- Progress bar placeholder – replaced dynamically -----------------
    LTEXT           "", IDC_PROGRESS,          158, 37, 97,  8

    // ---- Scene notes (multiline) -----------------------------------------
    LTEXT           "Notes:", IDC_STATIC,       158, 48, 97,  8
    EDITTEXT        IDC_SNAPNOTES,              158, 58, 97, 40,
                    ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL | WS_BORDER

    // ---- Status ----------------------------------------------------------
    LTEXT           "Idle",   IDC_STATUS,      158, 102, 97, 10

    // ---- Safes button ---------------------------------------------------
    PUSHBUTTON      "Safes...", IDC_SAFES_BTN,   158, 117, 97, 13

    // ---- Cue list setup button ------------------------------------------
    PUSHBUTTON      "Cue Setup...", IDC_CUE_SETUP_BTN, 158, 134, 97, 13

    // ---- Settings button (opens global settings) -------------------------
    PUSHBUTTON      "Settings...", IDC_SETTINGS_BTN, 158, 151, 97, 13
END

// ---------------------------------------------------------------------------
// IDD_SNAP_SETTINGS  -  Per-scene settings popup  (190 x 155 DU)
//   Transition settings (instant/duration/taper) + scene notes
// ---------------------------------------------------------------------------

IDD_SNAP_SETTINGS DIALOGEX 0, 0, 190, 165
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Scene Settings"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // ---- Notes ----------------------------------------------------------
    LTEXT           "Notes:", IDC_STATIC,   5,  5, 24, 8
    EDITTEXT        IDC_SNAPNOTES,          5, 15, 180, 36,
                    ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL | WS_BORDER

    // ---- Transition settings --------------------------------------------
    GROUPBOX        "Transition", IDC_STATIC, 4, 56, 181, 72

    CONTROL         "Instant", IDC_INSTANT, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 10, 69, 80, 10

    LTEXT           "Duration:", IDC_STATIC, 10, 83, 38, 8
    EDITTEXT        IDC_DURATION,            50, 81, 34, 12, ES_AUTOHSCROLL
    LTEXT           "sec",       IDC_STATIC, 86, 83, 18, 8

    LTEXT           "Taper:",    IDC_STATIC, 10, 98, 28, 8
    COMBOBOX        IDC_TAPER,              40, 96, 140, 70,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Exponent:", IDC_STATIC, 10, 113, 38, 8
    EDITTEXT        IDC_TAPER_CUSTOM,        50, 111, 34, 12, ES_AUTOHSCROLL

    // ---- Buttons --------------------------------------------------------
    DEFPUSHBUTTON   "OK",     IDOK,     80, 136, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 135, 136, 50, 14
END

// ---------------------------------------------------------------------------
// IDD_GLOBAL_SETTINGS  -  Global plugin settings  (205 x 142 DU)
//   Default transition settings applied to newly created scenes.
//   Also: place-marker-on-recall toggle.
// ---------------------------------------------------------------------------

IDD_GLOBAL_SETTINGS DIALOGEX 0, 0, 205, 142
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Global Settings"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    GROUPBOX        "New Scene Defaults", IDC_STATIC, 5, 5, 194, 83

    CONTROL         "Instant", IDC_GSET_INSTANT, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 10, 20, 80, 10

    LTEXT           "Duration:", IDC_STATIC,  10, 35, 38, 8
    EDITTEXT        IDC_GSET_DURATION,         52, 33, 34, 12, ES_AUTOHSCROLL
    LTEXT           "sec",       IDC_STATIC,   88, 35, 18, 8

    LTEXT           "Taper:",    IDC_STATIC,  10, 51, 28, 8
    COMBOBOX        IDC_GSET_TAPER,            40, 49, 154, 70,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Exponent:", IDC_STATIC,  10, 67, 38, 8
    EDITTEXT        IDC_GSET_TAPER_CUSTOM,     52, 65, 34, 12, ES_AUTOHSCROLL

    CONTROL         "Place marker at playhead on recall", IDC_GSET_MARKER, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP, 10, 95, 185, 10

    DEFPUSHBUTTON   "OK",     IDOK,      60, 120, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 120, 120, 50, 14
END

// ---------------------------------------------------------------------------
// IDD_CUE_SETUP  -  Cue list builder  (315 x 215 DU)
//   Left list: all scenes.  Right list: ordered cue list.
//   Drag from left to right to add; drag within right to reorder.
//   Double-click left list to append to cue.
// ---------------------------------------------------------------------------

IDD_CUE_SETUP DIALOGEX 0, 0, 315, 215
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Cue List Setup"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    LTEXT           "Scenes (drag or dbl-click \x2192)", IDC_STATIC, 5,  3, 148, 8
    LTEXT           "Cue Order",                         IDC_STATIC, 162, 3, 148, 8

    // List placeholders – replaced by SysListView32 in WM_INITDIALOG
    LTEXT           "", IDC_CUE_LEFT_LIST,   5, 13, 148, 198
    LTEXT           "", IDC_CUE_RIGHT_LIST, 162, 13, 148, 198
END

// ---------------------------------------------------------------------------
// IDD_SAFES  -  Per-channel safes grid  (430 x 252 DU)
//
//  Top:    "Global Safes" groupbox with two rows of checkboxes
//           Row 1: Vol Pan Mutes Solo Phase FX Vis
//           Row 2: Name Color Height Order
//  Middle: per-track safes ListView (built dynamically)
//  Bottom: Enable Per-Track toggle + Refresh / Clear All buttons
// ---------------------------------------------------------------------------

IDD_SAFES DIALOGEX 0, 0, 430, 252
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Live Tools - Safes"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // ---- Global Safes groupbox (two rows) --------------------------------
    GROUPBOX        "Global Safes", IDC_GSAFES_GROUP, 5, 4, 420, 52

    // Row 1 – mix params
    CONTROL "Vol",   IDC_GSAFE_VOL,   "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  12, 18, 46, 10
    CONTROL "Pan",   IDC_GSAFE_PAN,   "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  72, 18, 46, 10
    CONTROL "Mutes", IDC_GSAFE_MUTE,  "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 132, 18, 48, 10
    CONTROL "Solo",  IDC_GSAFE_SOLO,  "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 192, 18, 46, 10
    CONTROL "Phase", IDC_GSAFE_PHASE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 252, 18, 48, 10
    CONTROL "FX",    IDC_GSAFE_FX,    "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 312, 18, 40, 10
    CONTROL "Vis",   IDC_GSAFE_VIS,   "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 366, 18, 40, 10

    // Row 2 – layout params
    CONTROL "Name",   IDC_GSAFE_NAME,   "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  12, 34, 48, 10
    CONTROL "Color",  IDC_GSAFE_COLOR,  "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  72, 34, 48, 10
    CONTROL "Height", IDC_GSAFE_HEIGHT, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 132, 34, 52, 10
    CONTROL "Order",  IDC_GSAFE_ORDER,  "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 196, 34, 48, 10
    CONTROL "Layers", IDC_GSAFE_LAYERS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 256, 34, 48, 10

    // ---- Per-track safes -------------------------------------------------
    CONTROL "Enable Per-Track Safes", IDC_TRACK_SAFES_EN, "Button",
            BS_AUTOCHECKBOX | WS_TABSTOP, 5, 62, 130, 10

    // ListView placeholder – replaced dynamically in WM_INITDIALOG
    LTEXT           "", IDC_SAFESLIST, 5, 76, 420, 148

    // ---- Bottom buttons --------------------------------------------------
    PUSHBUTTON      "Refresh",   IDC_REFRESH_SAFES,  5, 230, 56, 14
    PUSHBUTTON      "Clear All", IDC_CLEAR_SAFES,   66, 230, 56, 14
END

// ---------------------------------------------------------------------------
// IDD_LAYOUTS  -  Layouts window  (280 x 260 DU)
//
//  Left  (x 5..159) : ListView (full height)
//  Right (x 164..274): Capture/Recall, Settings group, Nav buttons, Status
// ---------------------------------------------------------------------------

IDD_LAYOUTS DIALOGEX 0, 0, 280, 260
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Layouts"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // ListView placeholder – replaced dynamically in WM_INITDIALOG
    LTEXT           "", IDC_LAY_LIST, 5, 3, 154, 252

    // ---- Top action buttons ---------------------------------------------
    PUSHBUTTON      "Capture", IDC_LAY_CAPTURE, 164,   3, 50, 13
    PUSHBUTTON      "Recall",  IDC_LAY_RECALL,  218,   3, 56, 13

    // ---- Settings group -------------------------------------------------
    GROUPBOX        "Settings", IDC_LAY_SETTGRP, 163, 22, 111, 68

    CONTROL         "Track Order",   IDC_LAY_ORDER,  "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 168, 34, 70, 10
    CONTROL         "Heights",       IDC_LAY_HEIGHT, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 168, 46, 70, 10
    CONTROL         "Visibility",    IDC_LAY_VIS,    "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 168, 58, 70, 10
    CONTROL         "Track Names",   IDC_LAY_NAMES,  "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 168, 70, 70, 10

    // ---- Navigation -----------------------------------------------------
    PUSHBUTTON      "Prev",      IDC_LAY_PREV, 164, 98,  50, 13
    PUSHBUTTON      "Next",      IDC_LAY_NEXT, 218, 98,  56, 13

    // ---- Status ---------------------------------------------------------
    LTEXT           "Ready", IDC_LAY_STATUS, 164, 114, 110, 10
END

// ---------------------------------------------------------------------------
// IDD_LAYERS  -  Layers window  (487 x 357 DU)
//
//  Left  (x 5..216)   : Layer ListView (replaced dynamically), Add/Delete buttons
//  Right (x 221..480) : Layer Properties groupbox, name/maxch, Track ListView,
//                        Add/Remove/AddSpacer/Capture/Clear buttons
//  Bottom bar          : Activate Prev Next ShowAll Settings... + status
// ---------------------------------------------------------------------------

IDD_LAYERS DIALOGEX 0, 0, 487, 357
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Live Tools - Layers"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // ---- Left: Layers list -----------------------------------------------
    LTEXT           "Layers (double-click to activate):", IDC_STATIC, 5, 3, 170, 8

    // ListView placeholder – replaced dynamically in WM_INITDIALOG
    LTEXT           "", IDC_LYR_LAYER_LIST, 5, 13, 212, 292

    // Layer list management buttons
    PUSHBUTTON      "Add Layer",  IDC_LYR_ADD_LAYER,    5,  308, 56, 13
    PUSHBUTTON      "Delete",     IDC_LYR_DELETE_LAYER, 64, 308, 40, 13

    // ---- Right: Layer properties ----------------------------------------
    GROUPBOX        "Layer Properties", IDC_LYR_PROP_GROUP, 221, 3, 260, 327

    LTEXT           "Name:",    IDC_STATIC,       227, 18, 26, 8, SS_CENTERIMAGE
    EDITTEXT        IDC_LYR_NAME_EDIT,            255, 16, 219, 12, ES_AUTOHSCROLL

    LTEXT           "Max Ch:",  IDC_STATIC,       227, 34, 28, 8, SS_CENTERIMAGE
    EDITTEXT        IDC_LYR_MAXCH_EDIT,           257, 32, 36, 12, ES_NUMBER | ES_AUTOHSCROLL
    CONTROL         "", IDC_LYR_MAXCH_SPIN, "msctls_updown32",
                    UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_ARROWKEYS | WS_CHILD | WS_VISIBLE,
                    293, 32, 12, 12
    LTEXT           "(0 = all channels)", IDC_STATIC, 308, 34, 80, 8, SS_CENTERIMAGE

    LTEXT           "Tracks in Layer  (drag rows to reorder, right-click for options):", IDC_STATIC, 227, 50, 249, 8

    // ListView placeholder for track list – replaced dynamically
    LTEXT           "", IDC_LYR_TRACK_LIST, 226, 60, 249, 222

    // Track action buttons
    PUSHBUTTON      "Add Sel",   IDC_LYR_ADD_TRACK,   226, 286, 46, 13
    PUSHBUTTON      "Remove",    IDC_LYR_REM_TRACK,   275, 286, 46, 13
    PUSHBUTTON      "Add Spacer",IDC_LYR_ADD_SPACER,  324, 286, 60, 13
    PUSHBUTTON      "Capture",   IDC_LYR_CAPTURE,     387, 286, 46, 13
    PUSHBUTTON      "Clear",     IDC_LYR_CLEAR_LAYER, 436, 286, 38, 13

    // ---- Bottom bar ------------------------------------------------------
    PUSHBUTTON      "Activate",    IDC_LYR_ACTIVATE,     5,  341, 56, 13
    PUSHBUTTON      "Prev",        IDC_LYR_PREV,         64, 341, 36, 13
    PUSHBUTTON      "Next",        IDC_LYR_NEXT,        103, 341, 36, 13
    PUSHBUTTON      "Show All",    IDC_LYR_DEACTIVATE,  142, 341, 52, 13
    PUSHBUTTON      "Settings...", IDC_LYR_SETTINGS_BTN,197, 341, 58, 13
    LTEXT           "Ready",       IDC_LYR_STATUS,      259, 344, 222, 10
END

