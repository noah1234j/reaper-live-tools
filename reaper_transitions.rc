    EDITTEXT   IDC_TB_GAIN_LABEL, 222, 40, 48, 14, ES_RIGHT | ES_AUTOHSCROLL | WS_TABSTOP

    LTEXT      "Dim (dB):",       IDC_STATIC,          5,  58, 58, 10, SS_CENTERIMAGE
