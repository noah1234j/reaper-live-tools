// ---------------------------------------------------------------------------
// IDD_MONITOR_SETTINGS  -  Threshold settings dialog
// ---------------------------------------------------------------------------

IDD_MONITOR_SETTINGS DIALOGEX 0, 0, 200, 100
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Live Monitor - Thresholds"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // Column headers
    LTEXT           "",          IDC_STATIC,           5,  5, 72,  8
    LTEXT           "Yellow >",  IDC_STATIC,          80,  5, 30,  8, SS_CENTER
    LTEXT           "Orange >",  IDC_STATIC,         113,  5, 30,  8, SS_CENTER
    LTEXT           "Red >",     IDC_STATIC,         146,  5, 30,  8, SS_CENTER

    // CPU (values 0-100, interpreted as %)
    LTEXT           "CPU (%)",   IDC_STATIC,           5, 20, 72,  8, SS_CENTERIMAGE
    EDITTEXT        IDC_MON_CPU_YEL,  80, 18, 30, 12, ES_AUTOHSCROLL | ES_RIGHT
    EDITTEXT        IDC_MON_CPU_ORA, 113, 18, 30, 12, ES_AUTOHSCROLL | ES_RIGHT
    EDITTEXT        IDC_MON_CPU_RED, 146, 18, 30, 12, ES_AUTOHSCROLL | ES_RIGHT

    // I/O Latency
    LTEXT           "I/O (ms)",  IDC_STATIC,           5, 34, 72,  8, SS_CENTERIMAGE
    EDITTEXT        IDC_MON_IO_YEL,   80, 32, 30, 12, ES_AUTOHSCROLL | ES_RIGHT
    EDITTEXT        IDC_MON_IO_ORA,  113, 32, 30, 12, ES_AUTOHSCROLL | ES_RIGHT
    EDITTEXT        IDC_MON_IO_RED,  146, 32, 30, 12, ES_AUTOHSCROLL | ES_RIGHT

    // Max PDC
    LTEXT           "PDC (ms)",  IDC_STATIC,           5, 48, 72,  8, SS_CENTERIMAGE
    EDITTEXT        IDC_MON_PDC_YEL,  80, 46, 30, 12, ES_AUTOHSCROLL | ES_RIGHT
    EDITTEXT        IDC_MON_PDC_ORA, 113, 46, 30, 12, ES_AUTOHSCROLL | ES_RIGHT
    EDITTEXT        IDC_MON_PDC_RED, 146, 46, 30, 12, ES_AUTOHSCROLL | ES_RIGHT

    // Round-Trip
    LTEXT           "Round-Trip (ms)", IDC_STATIC,    5, 62, 72,  8, SS_CENTERIMAGE
    EDITTEXT        IDC_MON_RT_YEL,   80, 60, 30, 12, ES_AUTOHSCROLL | ES_RIGHT
    EDITTEXT        IDC_MON_RT_ORA,  113, 60, 30, 12, ES_AUTOHSCROLL | ES_RIGHT
    EDITTEXT        IDC_MON_RT_RED,  146, 60, 30, 12, ES_AUTOHSCROLL | ES_RIGHT

    // Buttons
    DEFPUSHBUTTON   "OK",        IDOK,          30, 82, 38, 14
    PUSHBUTTON      "Cancel",    IDCANCEL,      75, 82, 38, 14
    PUSHBUTTON      "Defaults",  IDC_MON_RESET,120, 82, 46, 14
END
