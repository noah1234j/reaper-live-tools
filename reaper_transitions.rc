    EDITTEXT   IDC_TB_DIM_LABEL,  222, 56, 48, 14, ES_RIGHT | ES_AUTOHSCROLL | WS_TABSTOP

    PUSHBUTTON "Routing...",      IDC_TB_ROUTE_BTN,    5,  76, 270, 14

    CONTROL    "Toggle",          IDC_TB_MODE_TOGGLE,    "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,  5,  96, 50, 10
    CONTROL    "Momentary",       IDC_TB_MODE_MOMENTARY, "Button", BS_AUTORADIOBUTTON,                         60,  96, 65, 10

    CONTROL    "Auto-Dim master when active", IDC_TB_AUTODIM,   "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  5, 112, 165, 10
    CONTROL    "Hide TB track fader",         IDC_TB_HIDEFADER, "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  5, 124, 125, 10
    CONTROL    "Active on project startup",   IDC_TB_AUTOSETUP, "Button", BS_AUTOCHECKBOX | WS_TABSTOP,  5, 136, 145, 10

    CONTROL    "TALKBACK OFF",    IDC_TB_TALK, "Button", BS_AUTOCHECKBOX | BS_PUSHLIKE | WS_TABSTOP, 5, 152, 270, 14
END

